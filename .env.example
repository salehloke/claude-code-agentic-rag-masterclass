# Option 1: Local Supabase CLI (active)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=  # New format: sb_publishable_* (run: npx supabase status)
SUPABASE_ANON_KEY=         # Legacy JWT anon key (older Supabase versions)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Option 2: Self-hosted on arr-stack via Tailscale (swap these to use remote)
# SUPABASE_URL=http://<tailscale-ip>:8000
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_DB_URL=postgresql://postgres:<password>@<tailscale-ip>:5432/postgres
# Gemini (no longer used - replaced by Ollama)
# GEMINI_API_KEY=
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_EMBEDDING_DIMENSIONS=768

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=jina/jina-embeddings-v2-base-en
OLLAMA_RERANKER_MODEL=bbjson/bge-reranker-base
OLLAMA_CHAT_MODEL=qwen2.5:3b

# Option 1: Local
SQL_READER_URL=postgresql://sql_reader:sql_reader_password@127.0.0.1:54322/postgres
# Option 2: Tailscale
# SQL_READER_URL=postgresql://sql_reader:<password>@<tailscale-ip>:5432/postgres
